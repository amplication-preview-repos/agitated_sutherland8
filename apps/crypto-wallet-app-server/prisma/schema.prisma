datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Transaction {
  amount          Float?
  createdAt       DateTime                        @default(now())
  id              String                          @id @default(cuid())
  status          EnumTransactionStatus?
  transactionType EnumTransactionTransactionType?
  updatedAt       DateTime                        @updatedAt
  wallet          Wallet?                         @relation(fields: [walletId], references: [id])
  walletId        String?
}

model P2PListing {
  amount      Float?
  createdAt   DateTime                   @default(now())
  id          String                     @id @default(cuid())
  listingType EnumP2PListingListingType?
  price       Float?
  status      EnumP2PListingStatus?
  updatedAt   DateTime                   @updatedAt
  wallet      Wallet?                    @relation(fields: [walletId], references: [id])
  walletId    String?
}

model Wallet {
  balance      Float?
  createdAt    DateTime            @default(now())
  currency     EnumWalletCurrency?
  id           String              @id @default(cuid())
  p2PListings  P2PListing[]
  transactions Transaction[]
  updatedAt    DateTime            @updatedAt
  user         User?               @relation(fields: [userId], references: [id])
  userId       String?
}

model User {
  createdAt  DateTime @default(now())
  id         String   @id @default(cuid())
  telegramId String?
  updatedAt  DateTime @updatedAt
  wallets    Wallet[]
}

enum EnumTransactionStatus {
  Option1
}

enum EnumTransactionTransactionType {
  Option1
}

enum EnumP2PListingListingType {
  Option1
}

enum EnumP2PListingStatus {
  Option1
}

enum EnumWalletCurrency {
  Option1
}
